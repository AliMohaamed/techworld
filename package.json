{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx turbo run dev --parallel",
    "dev:storefront": "npx turbo run dev --filter=@techworld/storefront",
    "dev:admin": "npx turbo run dev --filter=@techworld/admin",
    "dev:backend": "npm run dev --workspace @techworld/backend",
    "build": "npx turbo run build",
    "lint": "npx turbo run lint"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "typescript": "^5"
  }
}
