{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "CONVEX_DEPLOYMENT",
    "CONVEX_URL",
    "CONVEX_SITE_URL",
    "CONVEX_DEPLOY_KEY",
    "NEXT_PUBLIC_CONVEX_URL",
    "NEXT_PUBLIC_CONVEX_SITE_URL",
    "NEXT_PUBLIC_STOREFRONT_URL"
  ],
  "tasks": {
    "codegen": {
      "cache": false,
      "env": [
        "CONVEX_DEPLOYMENT",
        "CONVEX_DEPLOY_KEY"
      ]
    },
    "build": {
      "dependsOn": [
        "^build",
        "^codegen"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ],
      "env": [
        "CONVEX_DEPLOYMENT",
        "CONVEX_URL",
        "CONVEX_SITE_URL",
        "CONVEX_DEPLOY_KEY",
        "NEXT_PUBLIC_CONVEX_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    }
  }
}